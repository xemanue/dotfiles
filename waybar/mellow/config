    },

	"hyprland/workspaces": {
        "active-only": true,
        "show-special": true,
        "format": "{icon}",
        "format-icons": {
            "special": "S"
        }
    },
	
    "hyprland/window": {
        "format": "{title}",
    },

    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": {
            "capslock": "C{icon}  ",
            "numlock": "N{icon}"
