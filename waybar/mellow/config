// -*- mode: json -*-

{
	"layer": "top",
	"position": "top",
    "height": 32,

	"modules-left": [
		"hyprland/workspaces",
		"custom/right-arrow",
		"hyprland/window",
		"custom/right-arrow#gray"
	],
	"modules-right": [
		"keyboard-state",
        "custom/separator",
		"pulseaudio",
        "custom/separator",
		"backlight",
        "custom/separator",
        "network",
        "custom/left-arrow#gray",
		"battery",
		"custom/left-arrow",
        "clock"
	],

	"custom/right-arrow": {
