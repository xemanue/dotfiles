    "clock": {
        "format": "{:%H:%M}",
        "tooltip": true,
        "tooltip-format": "{calendar}",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#8caaee'><b>{}</b></span>",
                "days":       "<span color='#c6d0f5'><b>{}</b></span>",
                "weekdays":   "<span color='#babbf1'><b>{}</b></span>",
                "today":      "<span color='#8caaee'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click": "mode"
        }
    }
}
